# .env.example - Copy to .env and fill in your values

# Gemini API (optional - only if you want AI features)
GEMINI_API_KEY=

# Network settings
TCP_PORT=7777
MCAST_GRP=239.255.42.99
MCAST_PORT=6000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Node identity (optional - will be auto-generated if not set)
NODE_NAME=my_node
